# Cloudflare Turnstile secret keys for testing (https://developers.cloudflare.com/turnstile/troubleshooting/testing/#test-secret-keys)
CF_TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA" #	Always passes validation
# CF_TURNSTILE_SECRET_KEY="2x0000000000000000000000000000000AA" #	Always fails validation
# CF_TURNSTILE_SECRET_KEY="3x0000000000000000000000000000000AA" #	Returns 'token already spent' error

# Cloudflare Turnstile sitekeys for testing (https://developers.cloudflare.com/turnstile/troubleshooting/testing/#test-sitekeys)
# Widget type: visible
PUBLIC_CF_TURNSTILE_SITEKEY="1x00000000000000000000AA" # Always passes
# PUBLIC_CF_TURNSTILE_SITEKEY="2x00000000000000000000AB" # Always fails
# PUBLIC_CF_TURNSTILE_SITEKEY="3x00000000000000000000FF" # Forces interactive challenge
# Widget type: invisible
# PUBLIC_CF_TURNSTILE_SITEKEY="1x00000000000000000000BB" # Always passes
# PUBLIC_CF_TURNSTILE_SITEKEY="2x00000000000000000000BB" # Always fails

# https://resend.com/docs/dashboard/emails/send-test-emails
RECIPIENT_EMAIL="delivered@resend.dev"
