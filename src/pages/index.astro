---
import ContactForm from "~/components/ContactForm.astro";
import Layout from "~/layouts/Layout.astro";
import { tw } from "~/utils/tw";

export const prerender = true;

const title = "Astro & Resend Integration";
const description =
  "A functional contact form demonstrating serverless email delivery utilizing Astro, Resend, and Cloudflare Workers.";
---

<Layout title={title} description={description}>
  <section
    class={tw(
      "mx-auto grid max-w-lg gap-10",
      "lg:max-w-5xl lg:grid-cols-2 lg:gap-x-16",
    )}
  >
    <hgroup class="space-y-4 text-center lg:pt-8 lg:text-left">
      <h1
        class="text-3xl font-semibold tracking-tight text-neutral-50 sm:text-4xl"
      >
        {title}
      </h1>
      <p class="text-sm text-neutral-400 sm:text-base">
        {description}
      </p>
    </hgroup>

    <ContactForm />
  </section>
</Layout>
