---
import ContactForm from "~/components/ContactForm.astro";
import Layout from "~/layouts/Layout.astro";

const title = "Astro & Resend Integration";
const description =
  "A functional contact form demonstrating serverless email delivery utilizing Astro, Resend, and Cloudflare Workers.";
---

<Layout title={title} description={description}>
  <section class="mx-auto flex w-full max-w-lg flex-col gap-6">
    <hgroup class="space-y-2 text-center sm:text-left">
      <h1
        class="text-3xl font-semibold tracking-tight text-neutral-50 sm:text-4xl"
      >
        {title}
      </h1>
      <p class="text-sm text-neutral-400 sm:text-base">
        {description}
      </p>
    </hgroup>

    <ContactForm />
  </section>
</Layout>
