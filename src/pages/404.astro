---
import { ArrowLeftIcon } from "@phosphor-icons/react";
import Layout from "~/layouts/Layout.astro";
import { buttonStyles } from "~/styles/button";
import { tw } from "~/utils/tw";

export const prerender = true;

const DESCRIPTION =
  "Sorry, the page you are looking for does not exist or has been moved.";
---

<Layout title="404 – Page Not Found" description={DESCRIPTION} indexed={false}>
  <div class="mx-auto w-full max-w-lg text-center">
    <hgroup class="mb-4">
      <p class="text-sm font-medium tracking-widest text-neutral-400 uppercase">
        404 Error
      </p>
      <h1 class="mt-2 text-4xl font-bold text-neutral-100">Page Not Found</h1>
    </hgroup>
    <p class="text-neutral-400">{DESCRIPTION}</p>

    <div class="mt-8">
      <a href="/" class={tw("mx-auto w-fit", buttonStyles)}>
        <ArrowLeftIcon aria-hidden className="size-4.5" weight="bold" />
        Back to Home
      </a>
    </div>
  </div>
</Layout>
