---
import {
  CheckCircleIcon,
  CircleNotchIcon,
  PaperPlaneTiltIcon,
  WarningCircleIcon,
} from "@phosphor-icons/react";
import { tw } from "~/utils/tw";
import {
  EMAIL_MAX_LENGTH,
  MESSAGE_MAX_LENGTH,
  NAME_MAX_LENGTH,
  validationMessages,
} from "~/validation/messages";

type Props = {
  class?: string;
};

const { class: className } = Astro.props;

const fieldStyles = tw("flex flex-col gap-1.5");
const labelStyles = tw("text-sm font-medium text-neutral-300");
const errorStyles = tw(
  "min-h-lh text-sm text-red-400",
  "not-peer-user-invalid:invisible not-peer-user-invalid:opacity-0",
);
const inputStyles = tw(
  "peer rounded-lg border border-neutral-700 bg-neutral-800 px-3.5 py-2.5",
  "text-sm text-neutral-100 placeholder:text-neutral-500",
  "transition-colors hover:not-user-invalid:border-neutral-500",
  "user-invalid:border-red-500 user-invalid:focus-visible:outline-red-400",
);
---

<div
  class={tw(
    "w-full bg-neutral-900/70 p-8 backdrop-blur-sm",
    "relative rounded-2xl border border-neutral-800 shadow-xl",
    className,
  )}
>
  {/* Success Message */}
  <div
    class={tw(
      "absolute inset-0 grid place-content-center text-center",
      "invisible opacity-0 transition-opacity duration-300",
    )}
    id="contact-success"
  >
    <CheckCircleIcon
      aria-hidden
      className="mx-auto size-12 text-green-400"
      weight="fill"
    />
    <h2 class="mt-4 text-xl font-semibold text-neutral-100">Message Sent!</h2>
    <p class="mt-1.5 text-sm text-neutral-400">
      Thanks for reaching out. We'll get back to you as soon as possible.
    </p>
  </div>

  <form
    class="group/form transition-opacity duration-300"
    name="contact"
    novalidate
  >
    <h2 class="mb-6 text-xl font-semibold text-neutral-100">Contact Us</h2>

    {/* Honeypot field - hidden from real users, filled by bots */}
    <div aria-hidden="true" class="sr-only">
      <label for="contact-website">Website</label>
      <input
        autocomplete="off"
        id="contact-website"
        name="website"
        tabindex={-1}
        type="text"
      />
    </div>

    <div class="flex flex-col gap-5">
      {/* Name Field */}
      <div class={fieldStyles}>
        <label class={labelStyles} for="contact-name">Name</label>
        <input
          aria-errormessage="contact-name-error"
          autocomplete="name"
          class={inputStyles}
          id="contact-name"
          maxlength={NAME_MAX_LENGTH}
          name="name"
          placeholder="e.g. John Smith"
          required
          spellcheck="false"
          type="text"
        />
        <p class={errorStyles} id="contact-name-error">
          {validationMessages.name.valueMissing}
        </p>
      </div>

      {/* Email Field */}
      <div class={fieldStyles}>
        <label class={labelStyles} for="contact-email">Email</label>
        <input
          aria-errormessage="contact-email-error"
          autocomplete="email"
          class={inputStyles}
          id="contact-email"
          maxlength={EMAIL_MAX_LENGTH}
          name="email"
          placeholder="e.g. smith@example.com"
          required
          spellcheck="false"
          type="email"
        />
        <p class={errorStyles} id="contact-email-error">
          {validationMessages.email.valueMissing}
        </p>
      </div>

      {/* Message Field */}
      <div class={fieldStyles}>
        <label class={labelStyles} for="contact-message">Message</label>
        <textarea
          aria-errormessage="contact-message-error"
          class={tw(
            inputStyles,
            "field-sizing-content min-h-[calc(6lh+1.25rem+2px)]",
            "resize-y supports-[field-sizing:content]:resize-none",
          )}
          id="contact-message"
          maxlength={MESSAGE_MAX_LENGTH}
          name="message"
          placeholder="Tell us what's on your mind..."
          required></textarea>
        <p class={errorStyles} id="contact-message-error">
          {validationMessages.message.valueMissing}
        </p>
      </div>

      {/* Server Error Banner */}
      <div
        class={tw(
          "flex items-center gap-2 rounded-lg border border-red-500/30",
          "bg-red-500/10 px-4 py-3 text-sm text-red-400",
          "invisible opacity-0 transition-opacity duration-300",
        )}
        id="contact-server-error"
        role="alert"
      >
        <WarningCircleIcon
          aria-hidden
          className="size-5 shrink-0"
          weight="fill"
        />
        <p id="contact-server-error-message">
          Something went wrong. Please try again later.
        </p>
      </div>

      {/* Submit Button */}
      <button
        class={tw(
          "group mt-1 inline-flex items-center justify-center gap-2 rounded-lg px-5 py-2.5",
          "text-sm font-semibold text-neutral-900",
          "bg-neutral-100 transition hover:bg-white group-valid/form:active:scale-[0.98]",
          "data-[state=pending]:cursor-wait data-[state=pending]:opacity-80",
          "group-invalid/form:cursor-not-allowed",
          "group-invalid/form:opacity-80",
          "group-invalid/form:hover:bg-red-300",
        )}
        data-state="idle"
        type="submit"
      >
        {/* Idle State */}
        <span class="not-group-data-[state=idle]:hidden">Send message</span>
        <PaperPlaneTiltIcon
          aria-hidden
          className="size-4.5 not-group-data-[state=idle]:hidden"
          weight="fill"
        />

        {/* Pending State */}
        <span class="not-group-data-[state=pending]:hidden">Sending...</span>
        <CircleNotchIcon
          aria-hidden
          className="size-4.5 animate-spin not-group-data-[state=pending]:hidden"
          weight="bold"
        />
      </button>
    </div>
  </form>
</div>

<script>
  import { actions, isInputError } from "astro:actions";
  import { throwIfNull } from "~/utils/throw-if-null";
  import { validationMessages } from "~/validation/messages";

  const getErrorSetter = (
    errorElement: HTMLElement,
    field: HTMLInputElement | HTMLTextAreaElement,
  ) => {
    return (message: string): void => {
      errorElement.textContent = message;
      field.setCustomValidity(message);
    };
  };

  const hide = (element: Element): void => {
    element.classList.add("invisible", "opacity-0");
  };

  const show = (element: Element): void => {
    element.classList.remove("invisible", "opacity-0");
  };

  try {
    const form = throwIfNull(document.forms.namedItem("contact"));

    const submitButton = throwIfNull(
      form.querySelector<HTMLButtonElement>('button[type="submit"]'),
    );

    const setSubmitState = (state: "idle" | "pending"): void => {
      submitButton.dataset.state = state;
    };

    const serverError = throwIfNull(
      document.getElementById("contact-server-error"),
    );
    const serverErrorMessage = throwIfNull(
      document.getElementById("contact-server-error-message"),
    );

    const successMessage = throwIfNull(
      document.getElementById("contact-success"),
    );

    const nameInput = throwIfNull(document.getElementById("contact-name"));
    const emailInput = throwIfNull(document.getElementById("contact-email"));
    const messageInput = throwIfNull(
      document.getElementById("contact-message"),
    );

    if (!(nameInput instanceof HTMLInputElement))
      throw new Error("Name input is not an HTMLInputElement");
    if (!(emailInput instanceof HTMLInputElement))
      throw new Error("Email input is not an HTMLInputElement");
    if (!(messageInput instanceof HTMLTextAreaElement))
      throw new Error("Message input is not an HTMLTextAreaElement");

    const nameError = throwIfNull(
      document.getElementById("contact-name-error"),
    );
    const emailError = throwIfNull(
      document.getElementById("contact-email-error"),
    );
    const messageError = throwIfNull(
      document.getElementById("contact-message-error"),
    );

    const setNameError = getErrorSetter(nameError, nameInput);
    const setEmailError = getErrorSetter(emailError, emailInput);
    const setMessageError = getErrorSetter(messageError, messageInput);

    nameInput.addEventListener("input", () => {
      const { validity } = nameInput;

      switch (true) {
        case nameInput.value.trim() === "":
          setNameError(validationMessages.name.valueMissing);
          break;
        case validity.tooLong:
          setNameError(validationMessages.name.tooLong);
          break;
        default:
          setNameError("");
      }
    });

    emailInput.addEventListener("input", () => {
      const { validity } = emailInput;

      switch (true) {
        case emailInput.value.trim() === "":
          setEmailError(validationMessages.email.valueMissing);
          break;
        case validity.tooLong:
          setEmailError(validationMessages.email.tooLong);
          break;
        case validity.typeMismatch:
          setEmailError(validationMessages.email.typeMismatch);
          break;
        default:
          setEmailError("");
      }
    });

    messageInput.addEventListener("input", () => {
      const { validity } = messageInput;

      switch (true) {
        case messageInput.value.trim() === "":
          setMessageError(validationMessages.message.valueMissing);
          break;
        case validity.tooLong:
          setMessageError(validationMessages.message.tooLong);
          break;
        default:
          setMessageError("");
      }
    });

    form.addEventListener("submit", async (event): Promise<void> => {
      event.preventDefault();
      if (!form.checkValidity()) return; // Prevent invalid submissions
      if (submitButton.dataset.state === "pending") return; // Prevent duplicate submissions

      setSubmitState("pending");
      hide(serverError);
      const formData = new FormData(form);
      const response = await actions.send(formData);

      if (isInputError(response.error)) {
        const { name, email, message } = response.error.fields;

        if (name?.[0]) setNameError(name.join(" "));
        if (email?.[0]) setEmailError(email.join(" "));
        if (message?.[0]) setMessageError(message.join(" "));

        // Focus the first invalid field
        if (name?.[0]) nameInput.focus();
        else if (email?.[0]) emailInput.focus();
        else if (message?.[0]) messageInput.focus();

        setSubmitState("idle");
        return;
      }

      if (response.error) {
        console.error(response.error);
        serverErrorMessage.textContent = response.error.message;
        show(serverError);
        setSubmitState("idle");
        return;
      }

      hide(form);
      show(successMessage);
    });
  } catch (error) {
    console.error("Failed to initialize contact form:", error);
  }
</script>
