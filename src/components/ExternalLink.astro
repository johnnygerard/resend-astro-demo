---
import { tw } from "~/utils/tw";

type Props = {
  href: string;
  variant?: "default" | "inline";
};

const { href, variant = "default" } = Astro.props;
---

<a
  class={tw(
    "rounded-sm transition-colors hover:text-blue-400",
    {
      default: "-mx-1 px-1",
      inline: "text-neutral-300 underline",
    }[variant],
  )}
  href={href}
  rel="noopener noreferrer"
  target="_blank"><slot /></a
>
