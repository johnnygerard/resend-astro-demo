---
import { tw } from "~/utils/tw";

type Props = {
  class?: string;
  href: string;
};

const { class: className, href } = Astro.props;
---

<a
  class={tw(
    "-mx-1 rounded-sm px-1 transition-colors hover:text-blue-400",
    className,
  )}
  href={href}
  rel="noopener noreferrer"
  target="_blank"><slot /></a
>
